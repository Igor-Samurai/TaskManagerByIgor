<UserControl x:Class="TestTaskManager.View.UserControls.TaskItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
            Margin="5" Padding="15" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" 
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Description}" FontSize="14" 
                           TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CreatedAt, StringFormat='Создано: {0:dd.MM.yyyy HH:mm}'}" 
                               FontSize="12" Foreground="Blue" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding DueDate, StringFormat='Срок: {0:dd.MM.yyyy}'}" 
                               FontSize="12" Foreground="Orange"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Ellipse Width="12" Height="12" Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding Status}" FontSize="12" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding Priority}" FontSize="12" Foreground="Purple"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top">
                <Button Content="✏️ Изменить" Command="{Binding EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" Height="32" Margin="0,0,0,10"/>
                <Button Content="🗑️ Удалить" Command="{Binding DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" Background="#FF6B6B" Foreground="White" Height="32"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
