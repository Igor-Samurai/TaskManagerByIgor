<Window x:Class="TestTaskManager.View.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TestTaskManager.Model.Enums"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Добавить задачу" Height="650" Width="550" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="{Binding TaskTitle}" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <!-- Поля ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <StackPanel>
                <!-- Название -->
                <TextBlock Text="Название *" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" FontSize="14" Padding="12,8" 
                         MinWidth="450" Margin="0,0,0,15"/>

                <!-- Описание -->
                <TextBlock Text="Описание" Margin="0,15,0,5"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         Height="80" FontSize="14" Padding="12,8" 
                         MinWidth="450" Margin="0,0,0,15"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"/>

                <!-- Статус -->
                <TextBlock Text="Статус *" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Status}" Height="35" FontSize="14" 
                          Padding="12,8" MinWidth="450" Margin="0,0,0,15">
                    <ComboBoxItem Content="Активная" Tag="{x:Static local:Status.Active}"/>
                    <ComboBoxItem Content="Выполненная" Tag="{x:Static local:Status.Completed}"/>
                </ComboBox>

                <!-- Приоритет -->
                <TextBlock Text="Приоритет *" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Priority}" Height="35" FontSize="14" 
                          Padding="12,8" MinWidth="450" Margin="0,0,0,15">
                    <ComboBoxItem Content="Низкий" Tag="{x:Static local:Priority.Low}"/>
                    <ComboBoxItem Content="Средний" Tag="{x:Static local:Priority.Medium}"/>
                    <ComboBoxItem Content="Высокий" Tag="{x:Static local:Priority.High}"/>
                </ComboBox>

                <!-- Срок выполнения -->
                <TextBlock Text="Срок выполнения" Margin="0,15,0,5"/>
                <DatePicker DisplayDateStart="{x:Static sys:DateTime.Now}" SelectedDate="{Binding DueDate}" 
                            HorizontalContentAlignment="Left" FontSize="14"
                            MinWidth="450" Margin="0,0,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Width="100" Height="40" Margin="0,0,15,0" Background="#E0E0E0"/>
            <Button Content="Ок" Command="{Binding OperationCommand}" 
                    Width="100" Height="40" Background="#4CAF50" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>