<Window x:Class="TestTaskManager.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TestTaskManager"
        xmlns:sortOption="clr-namespace:TestTaskManager.ViewModel.Enums"
        xmlns:converters="clr-namespace:TestTaskManager.Converters"
        Title="Менеджер задач" Height="700" Width="1280">
    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="15,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <converters:IsDueDateExpiredConverter x:Key="IsDueDateExpiredConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="LightGray" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="➕ Добавить задачу" Command="{Binding AddCommand}" 
                        Width="140" Height="50" Margin="0,0,15,0"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Все задачи" IsChecked="True" Command="{Binding FilterStatusCommand}" CommandParameter="All"/>
                    <RadioButton Content="Активные" Command="{Binding FilterStatusCommand}" CommandParameter="Active"/>
                    <RadioButton Content="Завершённые" Command="{Binding FilterStatusCommand}" CommandParameter="Completed"/>
                </StackPanel>

                <Grid Margin="20,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Поиск:" VerticalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBox Grid.Row="1" Width="250" Text="{Binding FilterTitleOrDescription, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="8,5">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, RelativeSource={RelativeSource Self}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Setter Property="Text" Value="🔍 Поиск по названию и описанию..."/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Сортировка:"/>
                    <ComboBox Grid.Row="1" Width="160" SelectedValuePath="Tag" SelectedValue="{Binding SortOption}" VerticalContentAlignment="Center" Margin="0,0,20,0">
                        <ComboBoxItem Content="Дата создания" Tag="{x:Static sortOption:SortOption.DateCreate}"/>
                        <ComboBoxItem Content="Приоритет" Tag="{x:Static sortOption:SortOption.Priority}"/>
                        <ComboBoxItem Content="Срок" Tag="{x:Static sortOption:SortOption.DueDate}"/>
                    </ComboBox>
                </Grid>



                <!-- Кнопки Редактировать и Удалить -->
                <Button Content="✏️ Редактировать" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedUserTask}"
        Width="120" Height="35" Margin="0,0,10,0" />
                <Button Content="🗑️ Удалить" Command="{Binding RemoveCommand}" CommandParameter="{Binding SelectedUserTask}" 
        Width="100" Height="35" Margin="0,0,20,0"/>
                
            </StackPanel>
        </Border>

        <!-- Блоки с задачами -->
        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredTasksView}"
         SelectedItem="{Binding SelectedUserTask}" Margin="10"
         ScrollViewer.CanContentScroll="False"
         ScrollViewer.PanningMode="Both"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ScrollViewer.IsDeferredScrollingEnabled="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5" Width="900">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DueDate, Converter={StaticResource IsDueDateExpiredConverter}}" 
                                         Value="True">
                                        <Setter Property="Background" Value="#F9A8A4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="450"/>
                            <ColumnDefinition Width="450"/>
                        </Grid.ColumnDefinitions>

                        <!-- Первая колонка: Id, Title, Description -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock FontSize="12" FontWeight="Bold" 
                               Text="{Binding Id, StringFormat='ID: {0:N}'}" 
                               Foreground="Gray" Margin="0,0,0,5"/>
                            <TextBlock FontSize="18" FontWeight="SemiBold" 
                               Text="{Binding Title}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="14" Text="{Binding Description}" 
                               TextWrapping="Wrap" Foreground="DarkGray" MaxHeight="60"/>
                        </StackPanel>

                        <!-- Вторая колонка: Status, Priority, DueDate, CreatedAt -->
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="14" FontWeight="Bold" Text="Статус:" Foreground="Blue"/>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="5,0,0,0" Text="{Binding Status}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="14" FontWeight="Bold" Text="Приоритет:" Foreground="#4B0082"/>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="5,0,0,0" Text="{Binding Priority}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="14" FontWeight="Bold" Text="Срок:" Foreground="DarkGreen"/>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Margin="5,0,0,0" Text="{Binding DueDate, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="12" FontWeight="Bold" Text="Создано:" Foreground="DarkSlateGray"/>
                                <TextBlock FontSize="12" FontWeight="SemiBold" Margin="5,0,0,0" Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</Window>